{
  "name": "team-tally",
  "version": "0.0.1",
  "module": "index.ts",
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "dev:web": "bun run --filter @team-tally/web dev",
    "dev:mobile": "bun run --filter @team-tally/mobile dev",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip --no-config-hints"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "knip": "6.4.0",
    "oxlint": "1.59.0",
    "prettier": "3.8.2",
    "prettier-plugin-astro": "0.14.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
