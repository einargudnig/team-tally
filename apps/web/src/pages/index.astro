---
import Base from "../layouts/Base.astro";
import PhoneMockup from "../components/PhoneMockup.astro";
import Logo from "../components/logos/ChipCombMountain.astro";
// NOTE: The Roadmap section is hidden until the app ships.
// To re-enable: import Roadmap from "../components/Roadmap.astro"
// and drop <Roadmap /> back in below the features section.

const title = "Team Tally — The fine tracker for football teams";
const description =
  "Track team fines, settle the club kitty, and crown the weekly leaderboard. Team Tally is the simplest way for football teams and sports clubs to manage fines, dues, and accountability.";

const features = [
  {
    icon: "⚡",
    title: "Record fines in seconds",
    body: "Tap, pick the player, pick the offence — done. Built for the dressing room, not a spreadsheet.",
  },
  {
    icon: "🏆",
    title: "Live leaderboard",
    body: "See who's topping the charts for late arrivals, missed passes, and questionable haircuts.",
  },
  {
    icon: "💰",
    title: "Transparent kitty",
    body: "Everyone sees what they owe, what's been paid, and where the team treasury stands.",
  },
  {
    icon: "📱",
    title: "Works offline",
    body: "Log fines on the bus, on the pitch, in the pub. Syncs when you get back online.",
  },
  {
    icon: "🔒",
    title: "Private by default",
    body: "Your team's data stays on your device. No accounts required to get started.",
  },
  {
    icon: "🎯",
    title: "Custom fine types",
    body: "Every team has its own culture. Define the offences that matter to yours.",
  },
];
---

<Base title={title} description={description}>
  <!-- NAV -->
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="brand" aria-label="Team Tally home">
        <span class="brand-mark"><Logo size={28} /></span>
        <span>Team Tally</span>
      </a>
      <nav aria-label="Primary">
        <a href="#features">Features</a>
        <a href="#waitlist" class="nav-cta">Join waitlist</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">
          <span class="dot dot-live"></span> Launching soon · Built for grassroots football clubs
        </p>
        <h1>
          The fine tracker that <span class="accent">your team</span> will actually use.
        </h1>
        <p class="lede">
          Record fines, settle the kitty, and see who's really leading the dressing room table. Team
          Tally turns the oldest football tradition into a slick mobile app — no spreadsheets, no
          arguments, no excuses.
        </p>
        <div class="cta-row">
          <a href="#waitlist" class="btn btn-primary">Join the waitlist</a>
          <a href="#features" class="btn btn-ghost">See how it works →</a>
        </div>
        <ul class="trust">
          <li>✓ Free forever</li>
          <li>✓ No sign-up</li>
          <li>✓ Works offline</li>
        </ul>
      </div>
      <div class="hero-visual">
        <PhoneMockup />
      </div>
    </div>
    <div class="hero-bg" aria-hidden="true"></div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="features">
    <div class="section-head">
      <p class="eyebrow">Everything your treasurer needs</p>
      <h2>Built for the way teams actually work</h2>
      <p class="section-lede">
        No setup wizard. No onboarding friction. Just open the app, add a few players, and start
        fining.
      </p>
    </div>
    <div class="feat-grid">
      {
        features.map((f) => (
          <article class="feat-card">
            <span class="feat-icon" aria-hidden="true">
              {f.icon}
            </span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Roadmap hidden until launch — see note at top of file -->

  <!-- FOOTER -->
  <footer class="footer" id="waitlist">
    <div class="footer-inner">
      <div class="footer-cta">
        <p class="waitlist-kicker">
          <span class="dot dot-live"></span> Not out yet
        </p>
        <h2>Be first on the pitch.</h2>
        <p>
          Team Tally is launching for iOS and Android soon. Drop your email and we'll ping you the
          moment it's live.
        </p>
        <a
          href="mailto:hello@team-tally.app?subject=Team%20Tally%20waitlist&body=Add%20me%20to%20the%20waitlist."
          class="btn btn-primary"
        >
          Join the waitlist
        </a>
        <p class="waitlist-fine">No spam. One email when we launch, that's it.</p>
      </div>
      <div class="footer-meta">
        <span class="brand">
          <span class="brand-mark"><Logo size={22} /></span> Team Tally
        </span>
        <p>© {new Date().getFullYear()} Team Tally. Made for football teams everywhere.</p>
      </div>
    </div>
  </footer>

  <style>
    /* NAV */
    .nav {
      position: sticky;
      top: 0;
      z-index: 10;
      backdrop-filter: blur(12px);
      background: rgba(15, 15, 20, 0.7);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 16px;
      letter-spacing: -0.01em;
    }
    .brand-mark {
      color: var(--primary);
      --logo-cut: var(--surface);
      display: inline-flex;
      align-items: center;
    }
    .nav nav {
      display: flex;
      gap: 28px;
      align-items: center;
      font-size: 14px;
    }
    .nav nav a {
      color: var(--text-secondary);
      transition: color 0.15s;
    }
    .nav nav a:hover {
      color: var(--text-primary);
    }
    .nav-cta {
      background: var(--primary);
      color: var(--surface) !important;
      padding: 8px 16px;
      border-radius: 999px;
      font-weight: 600;
    }
    .nav-cta:hover {
      background: var(--primary-light);
    }

    /* HERO */
    .hero {
      position: relative;
      padding: 80px 24px 100px;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 40% at 20% 0%, rgba(245, 158, 11, 0.12), transparent 70%),
        radial-gradient(ellipse 60% 40% at 80% 100%, rgba(245, 158, 11, 0.08), transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      max-width: var(--max-width);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 600;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 20px;
    }
    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--primary);
      box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15);
    }
    /* Pulsing "live / coming soon" dot — used in hero eyebrow and waitlist footer */
    .dot-live {
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%,
      100% {
        box-shadow:
          0 0 0 0 rgba(245, 158, 11, 0.6),
          0 0 0 4px rgba(245, 158, 11, 0.15);
      }
      50% {
        box-shadow:
          0 0 0 8px rgba(245, 158, 11, 0),
          0 0 0 4px rgba(245, 158, 11, 0.15);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .dot-live {
        animation: none;
      }
    }
    h1 {
      font-size: clamp(40px, 5.5vw, 68px);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.025em;
      margin-bottom: 24px;
    }
    .accent {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .lede {
      font-size: 18px;
      color: var(--text-secondary);
      max-width: 560px;
      margin-bottom: 32px;
    }
    .cta-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 24px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 15px;
      transition: all 0.15s;
      border: 1px solid transparent;
    }
    .btn-primary {
      background: var(--primary);
      color: var(--surface);
      box-shadow: 0 8px 24px -8px rgba(245, 158, 11, 0.5);
    }
    .btn-primary:hover {
      background: var(--primary-light);
      transform: translateY(-1px);
    }
    .btn-ghost {
      color: var(--text-primary);
      border-color: var(--border);
    }
    .btn-ghost:hover {
      border-color: var(--primary);
      color: var(--primary);
    }
    .trust {
      display: flex;
      gap: 20px;
      list-style: none;
      font-size: 13px;
      color: var(--text-muted);
      flex-wrap: wrap;
    }

    .hero-visual {
      display: flex;
      justify-content: center;
    }

    /* FEATURES */
    .features {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 80px 24px;
    }
    .section-head {
      max-width: 720px;
      margin: 0 auto 56px;
      text-align: center;
    }
    h2 {
      font-size: clamp(32px, 4vw, 48px);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .section-lede {
      font-size: 17px;
      color: var(--text-secondary);
    }
    .feat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }
    .feat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      transition: all 0.2s;
    }
    .feat-card:hover {
      border-color: rgba(245, 158, 11, 0.4);
      transform: translateY(-2px);
    }
    .feat-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(245, 158, 11, 0.15);
      font-size: 22px;
      margin-bottom: 16px;
    }
    .feat-card h3 {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .feat-card p {
      color: var(--text-secondary);
      font-size: 15px;
    }

    /* FOOTER */
    .footer {
      margin-top: 40px;
      border-top: 1px solid var(--border);
      background: linear-gradient(180deg, transparent, rgba(245, 158, 11, 0.03));
    }
    .footer-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 80px 24px 40px;
    }
    .footer-cta {
      text-align: center;
      max-width: 580px;
      margin: 0 auto 60px;
    }
    .footer-cta h2 {
      margin-bottom: 12px;
    }
    .footer-cta p {
      color: var(--text-secondary);
      font-size: 17px;
      margin-bottom: 28px;
    }
    .waitlist-kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 12px !important;
      font-weight: 600;
      color: var(--primary) !important;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 16px !important;
      padding: 6px 14px;
      border-radius: 999px;
      background: rgba(245, 158, 11, 0.1);
      border: 1px solid rgba(245, 158, 11, 0.25);
    }
    .waitlist-fine {
      font-size: 13px !important;
      color: var(--text-muted) !important;
      margin-top: 20px !important;
      margin-bottom: 0 !important;
    }
    .footer-meta {
      padding-top: 32px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      color: var(--text-muted);
      font-size: 13px;
    }

    /* RESPONSIVE */
    @media (max-width: 860px) {
      .hero {
        padding: 56px 20px 72px;
      }
      .hero-grid {
        grid-template-columns: 1fr;
        gap: 48px;
        text-align: center;
      }
      .eyebrow,
      .cta-row,
      .trust {
        justify-content: center;
      }
      .lede {
        margin-left: auto;
        margin-right: auto;
      }
      .nav nav {
        gap: 16px;
      }
      .nav nav a:not(.nav-cta) {
        display: none;
      }
      .features {
        padding: 56px 20px;
      }
      .footer-inner {
        padding: 56px 20px 32px;
      }
    }
  </style>
</Base>
