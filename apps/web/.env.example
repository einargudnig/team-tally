# Resend (https://resend.com) — used for waitlist signups
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: segment within the audience to tag signups into.
# Create the "team-tally" segment in the Resend dashboard, then paste its ID here.
# If unset, contacts land in the audience without a segment.
RESEND_SEGMENT_ID=6188ab3f-daa6-471d-8cfb-e369cc9ce27a

# From address for the waitlist welcome email.
# Must be on a domain you've verified in Resend.
# For local dev you can use: onboarding@resend.dev
RESEND_FROM_EMAIL=Team Tally <hello@team-tally.app>
